# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
test/
wheels/
*.egg-info

# Virtual environments
.venv
.env

# IDE / Tooling
.vscode/
.claude/

# Data: ignore raw / processed payloads but keep the directory skeleton (.gitkeep / README.md)
data/raw/*
data/processed/*
data/cache/
!data/.gitkeep
!data/README.md
!data/raw/.gitkeep
!data/processed/.gitkeep

# Logs
logs/
*.log
